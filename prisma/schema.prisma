generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ENUMS
enum PaymentMethod {
  CASH
  PIX
  DEBIT
  CREDIT
}

enum OrderStatus {
  OPEN
  IN_PROGRESS
  FINISHED
  PAID
  CANCELLED
}

// MODELOS

model Client {
  id           String         @id @default(uuid())
  name         String
  phone        String
  email        String?
  address      String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  motorcycles  Motorcycle[]
  orders       OrderService[]
  sales        Sale[]         // 🚀 Nova relação com Vendas Diretas

  @@map("clients")
}

model Motorcycle {
  id        String         @id @default(uuid())
  plate     String         @unique
  brand     String?
  model     String?
  color     String?
  year      Int?
  
  clientId  String
  client    Client         @relation(fields: [clientId], references: [id])
  orders    OrderService[]
  createdAt DateTime       @default(now())

  @@map("motorcycles")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  sku         String?     @unique
  description String?
  price       Decimal     @db.Decimal(10, 2)
  costPrice   Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  minStock    Int         @default(2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  saleItems   SaleItem[]  // 🚀 Nova relação para itens de venda direta

  @@map("products")
}

// ESTRUTURA PARA ORDEM DE SERVIÇO (O.S.)
model OrderService {
  id             String         @id @default(uuid())
  number         Int            @unique @default(autoincrement())
  status         OrderStatus    @default(OPEN)
  description    String?
  laborValue     Decimal        @default(0) @db.Decimal(10, 2)
  totalValue     Decimal        @default(0) @db.Decimal(10, 2)
  
  paymentMethod  PaymentMethod?
  paidAt         DateTime?

  clientId       String
  client         Client         @relation(fields: [clientId], references: [id])
  motorcycleId   String
  motorcycle     Motorcycle     @relation(fields: [motorcycleId], references: [id])
  
  items          OrderItem[]
  services       ServiceItem[] 
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("order_services")
}

model ServiceItem {
  id             String       @id @default(uuid())
  description    String       
  price          Decimal      @db.Decimal(10, 2)
  
  orderServiceId String
  orderService   OrderService @relation(fields: [orderServiceId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())

  @@map("service_items")
}

model OrderItem {
  id             String       @id @default(uuid())
  quantity       Int
  unitPrice      Decimal      @db.Decimal(10, 2)
  
  orderServiceId String
  orderService   OrderService @relation(fields: [orderServiceId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// 🚀 NOVOS MODELOS: VENDA DIRETA (BALCÃO)

model Sale {
  id            String         @id @default(uuid())
  number        Int            @unique @default(autoincrement())
  totalValue    Decimal        @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  createdAt     DateTime       @default(now())

  clientId      String
  client        Client         @relation(fields: [clientId], references: [id])
  items         SaleItem[]

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}